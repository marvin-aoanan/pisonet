# ============================================
# PisoNet Backend Configuration
# ============================================
# Copy this file to .env and update values

# Server Configuration
NODE_ENV=development
PORT=5001
LOG_LEVEL=info

# Database Configuration
DATABASE_PATH=./pisonet.db

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5001,http://127.0.0.1:3000,http://127.0.0.1:5001,http://192.168.254.110:3000

# WebSocket Configuration
WS_PROTOCOL=ws
WS_HOST=localhost
WS_PORT=5001

# System Settings
PESO_TO_SECONDS=60
MAX_SESSION_DURATION=3600
AUTO_LOGOUT=true

# Cloud Deployment
CLOUD_ENV=development
CLOUD_PROVIDER=local

# Security (for authentication)
JWT_SECRET=your-secret-key-change-this
ADMIN_PASSWORD=admin123

# Production URLs (for cloud deployment)
API_URL=http://localhost:5001
FRONTEND_URL=http://192.168.254.110:3000

# Coin acceptor (standalone Orange Pi mode)
COIN_ACCEPTOR_ENABLED=true
SERIAL_PORT=/dev/ttyUSB0
BAUD_RATE=9600
COIN_VALUE=1
COIN_DEBOUNCE_MS=1
COIN_SETTLE_MS=500
COIN_PAYLOAD_MODE=pulse

# Touchscreen flow (tap unit -> insert coin timeout)
SELECTION_TIMEOUT_MS=30000
